{% comment %} VCN Blog listing {% endcomment %}
<div class="vcn-page">
  <h1>{{ blog.title }}</h1>

  <div class="vcn-blog-list">
    {% paginate blog.articles by 10 %}
      {% for article in blog.articles %}
        <a href="{{ article.url }}" class="vcn-blog-list__item">
          {% if article.image %}
            <img src="{{ article.image | img_url: '500x350', crop: 'center' }}" alt="{{ article.title }}">
          {% endif %}
          <div>
            <h3>{{ article.title }}</h3>
            <p style="color:rgba(255,255,255,0.4);font-size:0.85rem;">{{ article.published_at | date: '%d %b, %Y' }} — {{ article.author }}</p>
            <p style="color:rgba(255,255,255,0.6);">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
          </div>
        </a>
      {% endfor %}

      {% if paginate.pages > 1 %}
        <div class="vcn-pagination" style="text-align:center;margin-top:2rem;">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

<style>
.vcn-blog-list { display: flex; flex-direction: column; gap: 1.5rem; margin-top: 2rem; }
.vcn-blog-list__item { display: flex; gap: 1.5rem; text-decoration: none; color: #fff; align-items: flex-start; }
.vcn-blog-list__item img { width: 220px; border-radius: 12px; object-fit: cover; aspect-ratio: 10/7; flex-shrink: 0; }
@media(max-width:640px){ .vcn-blog-list__item { flex-direction: column; } .vcn-blog-list__item img { width: 100%; } }
</style>
