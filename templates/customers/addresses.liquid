{% comment %} VCN Customer addresses {% endcomment %}
<div class="vcn-page">
  <h1>{{ 'customer.addresses.title' | t }}</h1>

  {% form 'customer_address', customer.new_address %}
    <div class="vcn-form-field">
      <label for="AddressFirstName">First name</label>
      <input type="text" name="address[first_name]" id="AddressFirstName" value="{{ form.first_name }}">
    </div>
    <div class="vcn-form-field">
      <label for="AddressLastName">Last name</label>
      <input type="text" name="address[last_name]" id="AddressLastName" value="{{ form.last_name }}">
    </div>
    <div class="vcn-form-field">
      <label for="AddressAddress1">Address</label>
      <input type="text" name="address[address1]" id="AddressAddress1" value="{{ form.address1 }}">
    </div>
    <div class="vcn-form-field">
      <label for="AddressCity">City</label>
      <input type="text" name="address[city]" id="AddressCity" value="{{ form.city }}">
    </div>
    <div class="vcn-form-field">
      <label for="AddressPhone">Phone</label>
      <input type="tel" name="address[phone]" id="AddressPhone" value="{{ form.phone }}">
    </div>
    <button type="submit" class="vcn-btn">{{ 'customer.addresses.add_new' | t }}</button>
  {% endform %}

  <h3 style="margin-top:2.5rem;">{{ customer.addresses_count }} địa chỉ đã lưu</h3>
  {% for address in customer.addresses %}
    <div style="border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1rem;margin-bottom:0.8rem;">
      {{ address | format_address }}
      {% if address == customer.default_address %}
        <span style="color:#8B5CF6;font-size:0.8rem;">({{ 'customer.addresses.default' | t }})</span>
      {% endif %}
      {% form 'customer_address', address %}
        <button type="submit" name="_method" value="delete" class="vcn-btn vcn-btn--outline" style="margin-top:0.6rem;"
                onclick="return confirm('{{ 'customer.addresses.delete' | t }}?')">
          {{ 'customer.addresses.delete' | t }}
        </button>
      {% endform %}
    </div>
  {% endfor %}
</div>
