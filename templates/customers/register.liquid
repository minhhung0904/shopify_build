{% comment %} VCN Customer register {% endcomment %}
<div class="vcn-page" style="max-width:420px;">
  <h1>{{ 'customer.register.title' | t }}</h1>

  {% form 'create_customer' %}
    {% if form.errors %}
      <p style="color:#f87171;">{{ form.errors | default_errors }}</p>
    {% endif %}
    <div class="vcn-form-field">
      <label for="FirstName">{{ 'customer.register.first_name' | t }}</label>
      <input type="text" name="customer[first_name]" id="FirstName">
    </div>
    <div class="vcn-form-field">
      <label for="LastName">{{ 'customer.register.last_name' | t }}</label>
      <input type="text" name="customer[last_name]" id="LastName">
    </div>
    <div class="vcn-form-field">
      <label for="Email">{{ 'customer.register.email' | t }}</label>
      <input type="email" name="customer[email]" id="Email" required>
    </div>
    <div class="vcn-form-field">
      <label for="CreatePassword">{{ 'customer.register.password' | t }}</label>
      <input type="password" name="customer[password]" id="CreatePassword" required>
    </div>
    <button type="submit" class="vcn-btn">{{ 'customer.register.submit' | t }}</button>
  {% endform %}
</div>
