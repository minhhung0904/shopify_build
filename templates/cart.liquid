{% comment %} VCN Cart page {% endcomment %}
<div class="vcn-page vcn-cart">
  <h1>Giỏ Hàng</h1>

  {% if cart.item_count == 0 %}
    <div class="vcn-empty-state">
      <p>Giỏ hàng của bạn đang trống.</p>
      <a href="/collections/all" class="vcn-btn">Tiếp Tục Mua Sắm</a>
    </div>
  {% else %}
    {% form 'cart', cart, class: 'vcn-cart-form' %}
      <table class="vcn-table">
        <thead>
          <tr>
            <th>Sản phẩm</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Tổng</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr data-vcn-cart-line>
              <td>
                <a href="{{ item.url }}" style="display:flex;align-items:center;gap:0.8rem;text-decoration:none;color:#fff;">
                  {% if item.image %}
                    <img src="{{ item.image | img_url: '120x120', crop: 'center' }}" alt="{{ item.title }}" style="width:64px;height:64px;object-fit:cover;border-radius:8px;">
                  {% endif %}
                  <span>{{ item.product.title }}{% if item.variant.title != 'Default Title' %} — {{ item.variant.title }}{% endif %}</span>
                </a>
              </td>
              <td>{{ item.original_price | money }}</td>
              <td>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="vcn-form-field" style="width:70px;">
              </td>
              <td>{{ item.final_line_price | money }}</td>
              <td>
                <button type="button" class="vcn-btn vcn-btn--outline" data-vcn-remove-item>Xóa</button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div style="display:flex;justify-content:flex-end;gap:1rem;align-items:center;margin-top:2rem;flex-wrap:wrap;">
        <span style="font-size:1.2rem;font-weight:700;">Tạm tính: {{ cart.total_price | money }}</span>
        <button type="submit" name="update" class="vcn-btn vcn-btn--outline">Cập Nhật Giỏ Hàng</button>
        <button type="submit" name="checkout" class="vcn-btn">Thanh Toán</button>
      </div>
    {% endform %}
  {% endif %}
</div>
