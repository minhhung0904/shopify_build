{%- comment -%}
  Bundle on the PRODUCT PAGE (Kaching-style). Place this block on the product
  template. It shows the "Bundle & Save" picker only when the current product
  is the main product of an active bundle (bundle.products.first == product).
  Products without a matching bundle render nothing (normal product page).
{%- endcomment -%}

{%- comment -%}
  App-owned metaobject product_reference fields DON'T resolve on the storefront,
  so we match on the product HANDLES the app stores in the config JSON
  (config.productHandles). The current page product must be one of them.
{%- endcomment -%}
{%- assign matched = false -%}
{%- for bundle in shop.metaobjects["$app:bundle"].values -%}
  {%- if bundle.status.value == "active" and matched == false -%}
    {%- assign cfg = bundle.config.value -%}
    {%- if cfg.productHandles contains product.handle -%}
      {%- assign matched = bundle -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if matched -%}
  {%- assign matched_config = matched.config.value -%}
  {%- assign bundle_accent = matched_config.accentColor | default: block.settings.accent_color -%}
  {%- render 'bundle-picker-css',
    scope: block.id,
    bg: block.settings.background_color,
    text: block.settings.text_color,
    accent: bundle_accent,
    card_bg: block.settings.card_background_color,
    card_text: block.settings.card_text_color,
    highlight: block.settings.highlight_color,
    radius: block.settings.corner_radius,
    pad_top: block.settings.padding_top,
    pad_bottom: block.settings.padding_bottom,
    columns: 1
  -%}

  {%- style -%}
    .bundle-picker-{{ block.id }}.bpp { padding-left: 0; padding-right: 0; }
    .bundle-picker-{{ block.id }} .bpp-title {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      font-size: 1.7rem;
      font-weight: 800;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      margin: 0 0 1.4rem;
    }
    .bundle-picker-{{ block.id }} .bpp-title::before,
    .bundle-picker-{{ block.id }} .bpp-title::after {
      content: '';
      flex: 1 1 auto;
      height: 1px;
      background: color-mix(in srgb, currentColor 25%, transparent);
    }
    .bundle-picker-{{ block.id }} .bpp-inner { max-width: 56rem; }
  {%- endstyle -%}

  <div class="bundle-picker-{{ block.id }} bpp" {{ block.shopify_attributes }}>
    <div class="bpp-inner">
      {%- render 'bundle-form',
        block_id: block.id,
        handle: matched_config.handle,
        title: matched.title.value,
        main_product: product,
        products: matched.products.value,
        reward_products: matched.reward_products.value,
        bundle_type: matched.bundle_type.value,
        discount_type: matched.discount_type.value,
        discount_value: matched.discount_value.value,
        volume_tiers: matched.volume_tiers.value,
        min_items: matched.min_items.value,
        max_items: matched.max_items.value,
        config: matched.config.value
      -%}
    </div>
  </div>

  <script src="{{ 'bundle-picker.js' | asset_url }}" defer="defer"></script>
{%- elsif request.design_mode -%}
  {%- comment -%} Editor-only DEBUG so the mismatch is visible {%- endcomment -%}
  <div {{ block.shopify_attributes }} style="padding:1.6rem;border:1px dashed #c9c9c9;border-radius:8px;color:#374151;font-size:1.3rem;line-height:1.6;">
    <strong>Bundle on product — debug (editor only)</strong><br>
    Current product.handle = <code>{{ product.handle }}</code><br>
    No active bundle lists this product handle in config.productHandles. Bundles found:
    <ul style="margin:0.6rem 0 0;padding-left:1.6rem;">
      {%- for b in shop.metaobjects["$app:bundle"].values -%}
        {%- assign dbg_cfg = b.config.value -%}
        <li>
          &ldquo;{{ b.title.value }}&rdquo; · status=<code>{{ b.status.value }}</code>
          · productHandles=<code>{{ dbg_cfg.productHandles | join: ', ' }}</code>
          {%- if dbg_cfg.productHandles contains product.handle %} ← MATCH{% endif -%}
        </li>
      {%- else -%}
        <li>(no bundles returned by shop.metaobjects["$app:bundle"])</li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Bundle on product",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BUNDLE & SAVE"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#14110c"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Panel background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Panel text",
      "default": "#14110c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button / accent color",
      "default": "#E8B600"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight (selected tier, add-on band, pills)",
      "default": "#1d63e9"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "label": "Corner radius", "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Top padding", "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Bottom padding", "default": 16
    }
  ]
}
{% endschema %}
