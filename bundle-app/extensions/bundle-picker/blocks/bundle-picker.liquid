{%- comment -%}
  Bundle GRID block. Shows each bundle as a compact product-style card
  (image + title + price + Save badge). Fixed bundles quick-add to cart;
  other types link to the bundle detail page (?handle=...).
{%- endcomment -%}
{%- style -%}
  .bundle-picker-{{ block.id }} {
    --bp-bg: {{ block.settings.background_color }};
    --bp-text: {{ block.settings.text_color }};
    --bp-accent: {{ block.settings.accent_color }};
    --bp-card-bg: {{ block.settings.card_background_color }};
    --bp-card-text: {{ block.settings.card_text_color }};
    --bp-radius: {{ block.settings.corner_radius }}px;
    --bp-border: color-mix(in srgb, var(--bp-card-text) 14%, transparent);
    --bp-muted: color-mix(in srgb, var(--bp-card-text) 55%, transparent);
    padding: {{ block.settings.padding_top }}px 1.5rem {{ block.settings.padding_bottom }}px;
    background: var(--bp-bg);
    color: var(--bp-text);
  }

  .bundle-picker-{{ block.id }} .bp-wrap { max-width: 120rem; margin: 0 auto; }

  .bundle-picker-{{ block.id }} .bp-heading {
    text-align: center;
    font-size: clamp(2.2rem, 3vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 3rem;
  }

  .bundle-picker-{{ block.id }} .bpc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media screen and (min-width: 990px) {
    .bundle-picker-{{ block.id }} .bpc-grid {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .bundle-picker-{{ block.id }} .bpc-card {
    display: flex;
    flex-direction: column;
    background: var(--bp-card-bg);
    color: var(--bp-card-text);
    border: 1px solid var(--bp-border);
    border-radius: var(--bp-radius);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 8px 24px rgba(16, 24, 40, 0.06);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .bundle-picker-{{ block.id }} .bpc-card:hover {
    box-shadow: 0 2px 4px rgba(16, 24, 40, 0.06), 0 18px 42px rgba(16, 24, 40, 0.12);
    transform: translateY(-2px);
  }

  .bundle-picker-{{ block.id }} .bpc-card__link {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    text-decoration: none;
    color: inherit;
  }

  .bundle-picker-{{ block.id }} .bpc-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: color-mix(in srgb, var(--bp-card-text) 8%, transparent);
  }
  .bundle-picker-{{ block.id }} .bpc-card__img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .bundle-picker-{{ block.id }} .bpc-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    padding: 0.4rem 1rem;
    border-radius: 0.6rem;
    background: var(--bp-accent);
    color: #ffffff;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  .bundle-picker-{{ block.id }} .bpc-card__info {
    padding: 1.4rem 1.6rem 0.6rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1 1 auto;
  }
  .bundle-picker-{{ block.id }} .bpc-card__title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .bundle-picker-{{ block.id }} .bpc-card__price {
    margin: 0;
    font-size: 1.6rem;
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .bundle-picker-{{ block.id }} .bpc-card__from { font-size: 1.2rem; color: var(--bp-muted); font-weight: 600; }
  .bundle-picker-{{ block.id }} .bpc-card__now { color: var(--bp-accent); font-weight: 800; }
  .bundle-picker-{{ block.id }} .bpc-card__was { color: var(--bp-muted); font-weight: 500; font-size: 1.35rem; }

  .bundle-picker-{{ block.id }} .bpc-card__form { margin: 0 1.6rem 1.6rem; }
  .bundle-picker-{{ block.id }} a.bpc-card__cta { margin: 0 1.6rem 1.6rem; }

  .bundle-picker-{{ block.id }} .bpc-card__cta {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 1.2rem 1.4rem;
    border: none;
    border-radius: 0.8rem;
    background: var(--bp-accent);
    color: #ffffff;
    font-size: 1.45rem;
    font-weight: 800;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: filter 0.15s ease, transform 0.05s ease;
  }
  .bundle-picker-{{ block.id }} .bpc-card__form .bpc-card__cta { margin: 0; }
  .bundle-picker-{{ block.id }} .bpc-card__cta:hover:not(:disabled) { filter: brightness(0.94); }
  .bundle-picker-{{ block.id }} .bpc-card__cta:active:not(:disabled) { transform: translateY(1px); }
  .bundle-picker-{{ block.id }} .bpc-card__cta:disabled { opacity: 0.5; cursor: not-allowed; }

  .bundle-picker-{{ block.id }} .bpc-card__error {
    color: #ff6b6b;
    font-size: 1.2rem;
    margin: 0.5rem 1.6rem 0;
    display: none;
  }
  .bundle-picker-{{ block.id }} .bpc-card__error.is-visible { display: block; }
{%- endstyle -%}

<div class="bundle-picker-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="bp-wrap">
    {%- if block.settings.heading != blank -%}
      <h2 class="bp-heading">{{ block.settings.heading }}</h2>
    {%- endif -%}

    <ul class="bpc-grid" role="list">
      {%- for bundle in shop.metaobjects["$app:bundle"].values -%}
        {%- if bundle.status.value == "active" -%}
          {%- render 'bundle-card-compact',
            block_id: block.id,
            handle: bundle.handle,
            title: bundle.title.value,
            badge_text: bundle.badge_text.value,
            image: bundle.image.value,
            products: bundle.products.value,
            reward_products: bundle.reward_products.value,
            bundle_type: bundle.bundle_type.value,
            discount_type: bundle.discount_type.value,
            discount_value: bundle.discount_value.value,
            volume_tiers: bundle.volume_tiers.value,
            config: bundle.config.value,
            detail_url: block.settings.detail_url
          -%}
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</div>

<script src="{{ 'bundle-picker.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Bundle picker",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Bundles",
      "label": "Heading"
    },
    {
      "type": "url",
      "id": "detail_url",
      "label": "Bundle detail page",
      "info": "The page where you placed the 'Bundle detail' block, e.g. /pages/bundle"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4",
      "label": "Columns on desktop"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section text (heading)",
      "default": "#14110c"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text",
      "default": "#14110c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button / price / accent color",
      "default": "#f58220"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0, "max": 24, "step": 2, "unit": "px",
      "label": "Card corner radius", "default": 14
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Top padding", "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Bottom padding", "default": 60
    }
  ]
}
{% endschema %}
