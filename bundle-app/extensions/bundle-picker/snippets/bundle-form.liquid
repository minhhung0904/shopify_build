{%- comment -%}
  Type-aware bundle FORM (the buy UI), rendered by the bundle-product block
  on the product page. Accepts:
  block_id, handle, title, products, reward_products, bundle_type,
  discount_type, discount_value, volume_tiers, min_items, max_items, config
{%- endcomment -%}
    {%- case bundle_type -%}

      {%- when 'mix_match', 'infinite' -%}
        {%- if bundle_type == 'infinite' -%}
          {%- assign effective_max = 9999 -%}
        {%- else -%}
          {%- assign effective_max = max_items | default: products.size -%}
        {%- endif -%}
        <bundle-mix-match
          class="bp-card__form"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-discount-type="{{ discount_type }}"
          data-discount-value="{{ discount_value }}"
          data-min-items="{{ min_items | default: 1 }}"
          data-max-items="{{ effective_max }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <p class="bp-card__counter" data-bundle-counter>
            {%- if bundle_type == 'infinite' -%}
              Pick {{ min_items | default: 1 }}+ items
            {%- else -%}
              Pick {{ min_items | default: 1 }}–{{ max_items | default: products.size }} items
            {%- endif -%}
          </p>
          <ul class="bp-pool" role="list">
            {%- for product in products -%}
              {%- assign variant = product.selected_or_first_available_variant | default: product.variants.first -%}
              <li>
                <button
                  type="button"
                  class="bp-pool-item"
                  data-variant-id="{{ variant.id }}"
                  data-price="{{ variant.price }}"
                  {% unless product.available %}disabled{% endunless %}
                >
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                  <span class="bp-pool-item__title">{{ product.title }}</span>
                  <span class="bp-pool-item__price">{{ variant.price | money }}</span>
                </button>
              </li>
            {%- endfor -%}
          </ul>
          <p class="bp-card__price" data-bundle-price></p>
          <button type="button" class="bp-card__submit" data-bundle-submit disabled>
            Add bundle to cart
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-mix-match>

      {%- when 'variant' -%}
        {%- assign product = main_product | default: products.first -%}
        <bundle-mix-match
          class="bp-card__form"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-discount-type="{{ discount_type }}"
          data-discount-value="{{ discount_value }}"
          data-min-items="{{ min_items | default: 1 }}"
          data-max-items="{{ max_items | default: product.variants.size }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <p class="bp-card__counter" data-bundle-counter>
            Pick {{ min_items | default: 1 }}–{{ max_items | default: product.variants.size }} variants
          </p>
          <ul class="bp-pool" role="list">
            {%- for variant in product.variants -%}
              <li>
                <button
                  type="button"
                  class="bp-pool-item"
                  data-variant-id="{{ variant.id }}"
                  data-price="{{ variant.price }}"
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {%- if variant.featured_image != blank -%}
                    {{ variant.featured_image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                  {%- elsif product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                  {%- endif -%}
                  <span class="bp-pool-item__title">{{ variant.title }}</span>
                  <span class="bp-pool-item__price">{{ variant.price | money }}</span>
                </button>
              </li>
            {%- endfor -%}
          </ul>
          <p class="bp-card__price" data-bundle-price></p>
          <button type="button" class="bp-card__submit" data-bundle-submit disabled>
            Add bundle to cart
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-mix-match>

      {%- when 'multipack' -%}
        {%- assign product = main_product | default: products.first -%}
        {%- assign variant = product.selected_or_first_available_variant | default: product.variants.first -%}
        {%- assign pack_size = config.packSize | default: 1 -%}
        <bundle-multipack
          class="bp-card__form"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-discount-type="{{ discount_type }}"
          data-discount-value="{{ discount_value }}"
          data-pack-size="{{ pack_size }}"
          data-variant-id="{{ variant.id }}"
          data-price="{{ variant.price }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <p class="bp-card__counter">Pack of {{ pack_size }}</p>
          {%- if product.variants.size > 1 -%}
            <select class="bp-card__variant-select" data-bundle-variant-select>
              {%- for v in product.variants -%}
                <option
                  value="{{ v.id }}"
                  data-price="{{ v.price }}"
                  {% unless v.available %}disabled{% endunless %}
                  {% if v == variant %}selected{% endif %}
                >
                  {{ v.title }} ({{ v.price | money }})
                </option>
              {%- endfor -%}
            </select>
          {%- endif -%}
          <p class="bp-card__price" data-bundle-price></p>
          <button
            type="button"
            class="bp-card__submit"
            data-bundle-submit
            {% unless product.available %}disabled{% endunless %}
          >
            {%- if product.available -%}
              Add pack to cart
            {%- else -%}
              Sold out
            {%- endif -%}
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-multipack>

      {%- when 'bogo' -%}
        {%- assign buy_qty = config.buyQuantity | default: 1 -%}
        {%- assign get_qty = config.getQuantity | default: 1 -%}
        <bundle-bogo
          class="bp-card__form"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-buy-quantity="{{ buy_qty }}"
          data-get-quantity="{{ get_qty }}"
          data-reward-discount-type="{{ config.rewardDiscountType | default: 'percentage' }}"
          data-reward-discount-value="{{ config.rewardDiscountValue | default: 0 }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <p class="bp-card__counter">Buy {{ buy_qty }}</p>
          <select class="bp-card__variant-select" data-bogo-buy>
            {%- for product in products -%}
              {%- assign v = product.selected_or_first_available_variant | default: product.variants.first -%}
              <option
                value="{{ v.id }}"
                data-price="{{ v.price }}"
                {% unless product.available %}disabled{% endunless %}
              >
                {{ product.title }} ({{ v.price | money }})
              </option>
            {%- endfor -%}
          </select>
          <p class="bp-card__counter">Get {{ get_qty }}</p>
          <select class="bp-card__variant-select" data-bogo-get>
            {%- for product in reward_products -%}
              {%- assign v = product.selected_or_first_available_variant | default: product.variants.first -%}
              <option
                value="{{ v.id }}"
                data-price="{{ v.price }}"
                {% unless product.available %}disabled{% endunless %}
              >
                {{ product.title }} ({{ v.price | money }})
              </option>
            {%- endfor -%}
          </select>
          <p class="bp-card__price" data-bundle-price></p>
          <button type="button" class="bp-card__submit" data-bundle-submit>
            Add to cart
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-bogo>

      {%- when 'volume' -%}
        {%- assign product = main_product | default: products.first -%}
        {%- assign variant = product.selected_or_first_available_variant | default: product.variants.first -%}
        <bundle-volume
          class="bp-card__form"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-variant-id="{{ variant.id }}"
          data-price="{{ variant.price }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <div class="bp-qty">
            <button type="button" class="bp-qty__btn" data-bundle-qty-decrease>−</button>
            <input class="bp-qty__input" type="number" min="1" value="1" data-bundle-qty>
            <button type="button" class="bp-qty__btn" data-bundle-qty-increase>+</button>
          </div>
          <ul class="bp-tiers" role="list">
            {%- for tier in volume_tiers -%}
              <li
                class="bp-tier"
                data-min-quantity="{{ tier.minQuantity }}"
                data-discount-type="{{ tier.discountType }}"
                data-value="{{ tier.value }}"
              >
                <span>Buy {{ tier.minQuantity }}+</span>
                <span>
                  {%- if tier.discountType == 'percentage' -%}
                    {{ tier.value }}% off
                  {%- else -%}
                    {{ tier.value | times: 100 | money }} off
                  {%- endif -%}
                </span>
              </li>
            {%- endfor -%}
          </ul>
          <p class="bp-card__price" data-bundle-price>{{ variant.price | money }}</p>
          <button
            type="button"
            class="bp-card__submit"
            data-bundle-submit
            {% unless product.available %}disabled{% endunless %}
          >
            {%- if product.available -%}
              Add bundle to cart
            {%- else -%}
              Sold out
            {%- endif -%}
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-volume>

      {%- when 'tiered' -%}
        {%- assign product = main_product | default: products.first -%}
        <bundle-tiered
          class="bp-card__form bp-tiered"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-product-title="{{ product.title | escape }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <script type="application/json" data-bp-variants>
            [
              {%- for v in product.variants -%}
                {%- assign vimg = v.featured_image | default: product.featured_image -%}
                {%- if vimg -%}
                  {%- assign vimg_json = vimg | image_url: width: 200 | json -%}
                {%- else -%}
                  {%- assign vimg_json = 'null' -%}
                {%- endif -%}
                {"id":{{ v.id }},"title":{{ v.title | json }},"price":{{ v.price }},"available":{{ v.available }},"image":{{ vimg_json }}}{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          </script>
          <script type="application/json" data-bp-addons>
            [
              {%- comment -%} Add-ons resolved by handle (references don't resolve on storefront) {%- endcomment -%}
              {%- assign addon_sep = '' -%}
              {%- for h in config.addOnHandles -%}
                {%- assign ap = all_products[h] -%}
                {%- if ap != blank -%}
                  {%- assign av = ap.selected_or_first_available_variant | default: ap.variants.first -%}
                  {%- assign aimg = av.featured_image | default: ap.featured_image -%}
                  {%- if aimg -%}
                    {%- assign aimg_json = aimg | image_url: width: 120 | json -%}
                  {%- else -%}
                    {%- assign aimg_json = 'null' -%}
                  {%- endif -%}
                  {{ addon_sep }}{"id":{{ av.id }},"title":{{ ap.title | json }},"price":{{ av.price }},"available":{{ ap.available }},"image":{{ aimg_json }}}
                  {%- assign addon_sep = ',' -%}
                {%- endif -%}
              {%- endfor -%}
            ]
          </script>
          <script type="application/json" data-bp-addon-discount>
            {"discountType":{{ config.addOnDiscountType | default: 'percentage' | json }},"discountValue":{{ config.addOnDiscountValue | default: 0 }}}
          </script>

          <ul class="bp-tierlist" role="list" data-bp-tiers>
            {%- for tier in config.tiers -%}
              <li
                class="bp-tier2{% if tier.mostPopular %} is-popular{% endif %}"
                data-tier-index="{{ forloop.index0 }}"
                data-quantity="{{ tier.quantity }}"
                data-discount-type="{{ tier.discountType }}"
                data-discount-value="{{ tier.discountValue }}"
              >
                <label class="bp-tier2__head">
                  <input
                    type="radio"
                    name="bp-tier-{{ block_id }}-{{ handle }}"
                    class="bp-tier2__radio"
                    value="{{ forloop.index0 }}"
                    {% if tier.mostPopular %}checked{% endif %}
                  >
                  <span class="bp-tier2__info">
                    <span class="bp-tier2__title">
                      {{ tier.title | default: tier.quantity }}
                      {%- if tier.discountValue > 0 -%}
                        <span class="bp-tier2__savepill" data-bp-savepill></span>
                      {%- endif -%}
                    </span>
                    <span class="bp-tier2__sub" data-bp-sub></span>
                  </span>
                  <span class="bp-tier2__prices">
                    <span class="bp-tier2__now" data-bp-now></span>
                    <s class="bp-tier2__was" data-bp-was></s>
                  </span>
                  {%- if tier.mostPopular -%}
                    <span class="bp-tier2__ribbon">Most Popular</span>
                  {%- endif -%}
                </label>
                <div class="bp-tier2__body" data-bp-body hidden></div>
              </li>
            {%- endfor -%}
          </ul>

          <button type="button" class="bp-card__submit" data-bundle-submit>
            Add bundle to cart
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-tiered>

      {%- else -%}
        {%- comment -%} fixed bundle: every product included {%- endcomment -%}
        {%- assign bundle_available = true -%}
        <bundle-add-to-cart
          class="bp-card__form"
          data-bundle-handle="{{ handle }}"
          data-bundle-title="{{ title | escape }}"
          data-discount-type="{{ discount_type }}"
          data-discount-value="{{ discount_value }}"
          data-currency="{{ cart.currency.iso_code }}"
          data-cart-add-url="{{ routes.cart_add_url }}"
          data-cart-url="{{ routes.cart_url }}"
        >
          <ul class="bp-pool" role="list" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem;">
            {%- for product in products -%}
              {%- unless product.available -%}{%- assign bundle_available = false -%}{%- endunless -%}
              <li>
                {%- if product.variants.size > 1 -%}
                  <select class="bp-card__variant-select" data-product-variants>
                    {%- for variant in product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        {% unless variant.available %}disabled{% endunless %}
                        {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                      >
                        {{ product.title }} — {{ variant.title }} ({{ variant.price | money }})
                      </option>
                    {%- endfor -%}
                  </select>
                {%- else -%}
                  {%- assign variant = product.selected_or_first_available_variant | default: product.variants.first -%}
                  <span data-product-variants data-fixed-variant-id="{{ variant.id }}" data-price="{{ variant.price }}">
                    {{ product.title }} ({{ variant.price | money }})
                  </span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
          <p class="bp-card__price" data-bundle-price></p>
          <button
            type="button"
            class="bp-card__submit"
            data-bundle-submit
            {% unless bundle_available %}disabled{% endunless %}
          >
            {%- if bundle_available -%}
              Add bundle to cart
            {%- else -%}
              Sold out
            {%- endif -%}
          </button>
          <p class="bp-card__error" data-bundle-error role="alert"></p>
        </bundle-add-to-cart>

    {%- endcase -%}
