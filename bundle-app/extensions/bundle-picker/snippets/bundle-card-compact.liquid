{%- comment -%}
  Compact product-style card for one bundle (grid view).
  Whole card links to the bundle detail page. Fixed bundles also get a
  quick "Add to cart"; other types show "Choose options" -> detail page.

  Accepts:
    block_id, handle, title, badge_text, image, products, reward_products,
    bundle_type, discount_type, discount_value, volume_tiers, config,
    detail_url  (base path of the detail page, e.g. "/pages/bundle")
{%- endcomment -%}

{%- liquid
  assign first_product = products.first
  assign card_image = image
  if card_image == blank
    assign card_image = first_product.featured_image
  endif

  # ---- Representative regular price (compare-at), in cents ----
  # Sum one variant per product = "buy them separately" price.
  assign compare_cents = 0
  for product in products
    assign rv = product.selected_or_first_available_variant | default: product.variants.first
    assign compare_cents = compare_cents | plus: rv.price
  endfor

  # ---- Which discount applies for the card's headline price ----
  assign eff_type = discount_type
  assign eff_value = discount_value
  assign price_from = false

  case bundle_type
    when 'tiered'
      # Use the most-popular tier (fallback: first) as the headline offer.
      assign chosen_tier = config.tiers.first
      for t in config.tiers
        if t.mostPopular
          assign chosen_tier = t
        endif
      endfor
      assign unit = first_product.selected_or_first_available_variant.price | default: first_product.variants.first.price
      assign qty = chosen_tier.quantity | default: 1
      assign compare_cents = unit | times: qty
      assign eff_type = chosen_tier.discountType
      assign eff_value = chosen_tier.discountValue
    when 'multipack'
      assign pack = config.packSize | default: 1
      assign unit = first_product.selected_or_first_available_variant.price | default: first_product.variants.first.price
      assign compare_cents = unit | times: pack
    when 'volume'
      assign price_from = true
    when 'mix_match', 'infinite', 'variant', 'bogo'
      # Price varies with selection: show a "from cheapest item" floor.
      assign price_from = true
      assign cheapest = 0
      for product in products
        assign rv = product.selected_or_first_available_variant | default: product.variants.first
        if cheapest == 0 or rv.price < cheapest
          assign cheapest = rv.price
        endif
      endfor
      assign compare_cents = cheapest
  endcase

  # ---- Apply the discount to get the "now" price, in cents ----
  assign now_cents = compare_cents
  if eff_value > 0
    if eff_type == 'percentage'
      assign keep = 100.0 | minus: eff_value
      assign now_cents = compare_cents | times: keep | divided_by: 100 | round
    elsif eff_type == 'fixed_amount'
      assign off = eff_value | times: 100
      assign now_cents = compare_cents | minus: off
    elsif eff_type == 'fixed_price'
      assign now_cents = eff_value | times: 100
    endif
  endif
  if now_cents < 0
    assign now_cents = 0
  endif

  # ---- Save badge ----
  assign has_saving = false
  if now_cents < compare_cents
    assign has_saving = true
    assign save_pct = compare_cents | minus: now_cents | times: 100 | divided_by: compare_cents
  endif

  # ---- Button behaviour by type ----
  assign needs_options = true
  if bundle_type == 'fixed' or bundle_type == blank
    assign needs_options = false
  endif

  assign link = detail_url | default: '/pages/bundle'
  assign link = link | append: '?handle=' | append: handle
-%}

<li class="bpc-card">
  <a class="bpc-card__link" href="{{ link }}" aria-label="{{ title | escape }}">
    <div class="bpc-card__media">
      {%- if badge_text != blank -%}
        <span class="bpc-card__badge">{{ badge_text }}</span>
      {%- elsif has_saving -%}
        <span class="bpc-card__badge">Save {{ save_pct }}%</span>
      {%- endif -%}
      {%- if card_image != blank -%}
        {{ card_image | image_url: width: 720 | image_tag: loading: 'lazy', widths: '360,720', class: 'bpc-card__img' }}
      {%- endif -%}
    </div>
    <div class="bpc-card__info">
      <h3 class="bpc-card__title">{{ title }}</h3>
      <p class="bpc-card__price">
        {%- if price_from -%}<span class="bpc-card__from">from</span> {% endif -%}
        <span class="bpc-card__now">{{ now_cents | money }}</span>
        {%- if has_saving -%}
          <s class="bpc-card__was">{{ compare_cents | money }}</s>
        {%- endif -%}
      </p>
    </div>
  </a>

  {%- if needs_options -%}
    <a class="bpc-card__cta" href="{{ link }}">Choose options</a>
  {%- else -%}
    {%- comment -%} Fixed bundle: quick add reuses the existing BundleFixed element {%- endcomment -%}
    <bundle-add-to-cart
      class="bpc-card__form"
      data-bundle-handle="{{ handle }}"
      data-bundle-title="{{ title | escape }}"
      data-discount-type="{{ discount_type }}"
      data-discount-value="{{ discount_value }}"
      data-currency="{{ cart.currency.iso_code }}"
      data-cart-add-url="{{ routes.cart_add_url }}"
      data-cart-url="{{ routes.cart_url }}"
    >
      <div hidden>
        {%- for product in products -%}
          {%- assign v = product.selected_or_first_available_variant | default: product.variants.first -%}
          <span data-product-variants data-fixed-variant-id="{{ v.id }}" data-price="{{ v.price }}"></span>
        {%- endfor -%}
      </div>
      <button type="button" class="bpc-card__cta" data-bundle-submit>Add to cart</button>
      <p class="bpc-card__error" data-bundle-error role="alert"></p>
    </bundle-add-to-cart>
  {%- endif -%}
</li>
