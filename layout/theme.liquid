<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#0a0a0f">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- if settings.font_import_url != blank %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="{{ settings.font_import_url }}">
  {%- endif %}

  <style>
    :root {
      --vcn-font-primary: {{ settings.font_family }};
    }
  </style>

  {{ content_for_header }}

  {{ 'vcn-base.css' | asset_url | stylesheet_tag }}
</head>

<body class="vcn-body">

  <a class="vcn-skip-link" href="#MainContent">Chuyển đến nội dung chính</a>

  {% section 'vcn-navbar' %}

  <main role="main" id="MainContent">
    {{ content_for_layout }}
  </main>

  {% section 'vcn-footer' %}

  {{ 'vcn-base.js' | asset_url | script_tag }}
</body>
</html>
