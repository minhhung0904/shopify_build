{
  "name": "t:sections.header.name",
  "type": "header",
  "sections": {
    "marquee-ticker": {
      "type": "marquee-ticker",
      "settings": {
        "color_scheme": "scheme-5",
        "speed": 40,
        "pause_on_hover": true,
        "padding_mobile": 9,
        "padding_desktop": 9
      },
      "blocks": {
        "marquee-0": {
          "type": "message",
          "settings": {
            "text": "New arrivals every week",
            "link": ""
          }
        },
        "marquee-1": {
          "type": "message",
          "settings": {
            "text": "Limited time offers",
            "link": ""
          }
        },
        "marquee-2": {
          "type": "message",
          "settings": {
            "text": "Free shipping on all orders",
            "link": ""
          }
        }
      },
      "block_order": [
        "marquee-0",
        "marquee-1",
        "marquee-2"
      ]
    },
    "header": {
      "type": "header",
      "settings": {
        "color_scheme": "scheme-1",
        "menu_color_scheme": "scheme-1",
