{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .testimonials-{{ section.id }} .testimonials__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .testimonials-{{ section.id }} .testimonials__rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.2rem;
    font-size: 2.4rem;
    font-weight: 800;
  }

  .testimonials-{{ section.id }} .testimonials__stars {
    display: inline-flex;
    gap: 0.2rem;
    color: #FFC107;
    line-height: 0;
  }

  .testimonials-{{ section.id }} .testimonials__stars svg {
    width: 2.8rem;
    height: 2.8rem;
    fill: #FFC107;
    color: #FFC107;
  }

  .testimonials-{{ section.id }} .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
  }

  @media screen and (min-width: 600px) {
    .testimonials-{{ section.id }} .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .testimonials-{{ section.id }} .testimonials__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  .testimonials-{{ section.id }} .testimonials__card {
    position: relative;
    background: color-mix(in srgb, rgb(var(--color-foreground)) 4%, rgb(var(--color-background)));
    border-radius: var(--product-card-corner-radius, 1.2rem);
    padding: 2.4rem 2rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .testimonials-{{ section.id }} .testimonials__card-top {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .testimonials-{{ section.id }} .testimonials__card .testimonials__stars svg {
    width: 1.8rem;
    height: 1.8rem;
  }

  .testimonials-{{ section.id }} .testimonials__quote-icon {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    background: var(--testimonials-quote-color, #1d63e9);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
  }

  .testimonials-{{ section.id }} .testimonials__title {
    margin: 0;
    font-weight: 700;
  }

  .testimonials-{{ section.id }} .testimonials__quote {
    margin: 0;
    line-height: 1.5;
    font-weight: 700;
  }

  .testimonials-{{ section.id }} .testimonials__divider {
    border: none;
    border-top: 1px solid rgba(var(--color-foreground), 0.12);
    margin: 0.4rem 0;
    width: 100%;
  }

  .testimonials-{{ section.id }} .testimonials__author {
    font-weight: 700;
    font-style: italic;
    margin: 0;
  }
{%- endstyle -%}

{%- capture star_svg -%}<svg class="icon icon-star" viewBox="0 0 24 24" role="presentation" focusable="false"><path d="M12 2.5l2.7 6.6 7.1.5-5.4 4.6 1.7 6.9L12 17.9l-6.1 3.2 1.7-6.9L2.2 9.6l7.1-.5z"/></svg>{%- endcapture -%}

<div class="color-{{ section.settings.color_scheme }} gradient testimonials-{{ section.id }}">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="testimonials__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="title title-wrapper--no-top-margin inline-richtext title-with-highlight {{ section.settings.heading_size }}" style="--hightlight-color: rgba(0, 182, 122, 0.3);">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.show_rating -%}
        <div class="testimonials__rating">
          <span>{{ section.settings.rating_text }}</span>
          <span class="testimonials__stars">
            {%- for i in (1..5) -%}
              {{- star_svg -}}
            {%- endfor -%}
          </span>
        </div>
      {%- endif -%}
    </div>

    <ul class="testimonials__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="testimonials__card" {{ block.shopify_attributes }}>
          <div class="testimonials__card-top">
            <span class="testimonials__stars">
              {%- assign stars = block.settings.rating | default: 5 -%}
              {%- for i in (1..stars) -%}
                {{- star_svg -}}
              {%- endfor -%}
            </span>
            <span class="testimonials__quote-icon" aria-hidden="true">&rdquo;</span>
          </div>
          {%- if block.settings.title != blank -%}
            <p class="testimonials__title">&ldquo;{{ block.settings.title }}&rdquo;</p>
          {%- endif -%}
          <p class="testimonials__quote">{{ block.settings.quote }}</p>
          <hr class="testimonials__divider">
          <p class="testimonials__author">{{ block.settings.author }}</p>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Customer reviews",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "Show rating summary"
    },
    {
      "type": "text",
      "id": "rating_text",
      "default": "4.8 out of 5 based on verified reviews",
      "label": "Rating text"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4",
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Short quote (optional)",
          "info": "Shown in bold above the review text, e.g. \"Worth the purchase\""
        },
        {
          "type": "textarea",
          "id": "quote",
          "default": "Amazing quality and it looks incredible lit up at night. Shipping was fast too!",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Verified Customer",
          "label": "Author name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "quote": "The quality is amazing, way better than I expected. Perfect gift for anyone.", "author": "Jordan M." } },
        { "type": "review", "settings": { "quote": "Packaging was solid, arrived without a scratch, and it looks even better in person.", "author": "Alicia R." } },
        { "type": "review", "settings": { "quote": "Customer service answered all my questions fast and the product exceeded my expectations.", "author": "Marcus T." } },
        { "type": "review", "settings": { "quote": "Bought one for myself and one as a gift, both were a huge hit. Will be ordering again.", "author": "Priya S." } }
      ]
    }
  ]
}
{% endschema %}
