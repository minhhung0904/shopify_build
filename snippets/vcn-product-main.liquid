{% comment %} VCN High-Converting Product Markup — shared by templates/product.liquid and templates/product.vcn.liquid {% endcomment %}
<div class="vcn-product" itemscope itemtype="https://schema.org/Product">

  <div class="vcn-product__layout">

    {%- comment -%} LEFT: Images {%- endcomment -%}
    <div class="vcn-product__gallery">
      <div class="vcn-product__main-img" id="vcn-main-img">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: '700x700', crop: 'center' }}"
               alt="{{ product.title }}"
               id="vcn-main-img-el"
               itemprop="image">
        {% else %}
          <div class="vcn-product__img-placeholder">
            <svg viewBox="0 0 200 200" fill="none"><circle cx="100" cy="100" r="60" stroke="rgba(139,92,246,0.4)" stroke-width="2"/><circle cx="100" cy="100" r="8" fill="#8B5CF6"/></svg>
          </div>
        {% endif %}
        {% if product.compare_at_price > product.price %}
          <div class="vcn-product__badge">
            -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}% OFF
          </div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="vcn-product__thumbs">
          {% for image in product.images limit: 6 %}
            <button class="vcn-thumb {% if forloop.first %}vcn-thumb--active{% endif %}"
                    onclick="vcnSwitchImg('{{ image | img_url: '700x700' }}', this)">
              <img src="{{ image | img_url: '120x120', crop: 'center' }}" alt="{{ product.title }} {{ forloop.index }}">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {%- comment -%} RIGHT: Info {%- endcomment -%}
    <div class="vcn-product__info">

      <div class="vcn-product__stars">
        <span class="vcn-stars-fill">★★★★★</span>
        <span class="vcn-stars-count">4.9 (127 đánh giá)</span>
      </div>

      <h1 class="vcn-product__title" itemprop="name">{{ product.title }}</h1>

      <div class="vcn-product__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <span class="vcn-price-current" itemprop="price" content="{{ product.price | divided_by: 100 }}">
          {{ product.price | money }}
        </span>
        {% if product.compare_at_price > product.price %}
          <span class="vcn-price-original">{{ product.compare_at_price | money }}</span>
          <span class="vcn-price-save">
            Tiết kiệm {{ product.compare_at_price | minus: product.price | money }}
          </span>
        {% endif %}
      </div>

      {%- comment -%} Urgency bar {%- endcomment -%}
      <div class="vcn-urgency">
        <div class="vcn-urgency__dot"></div>
        <span>🔥 <strong>23 người</strong> đang xem sản phẩm này</span>
      </div>

      {%- comment -%} Variants {%- endcomment -%}
      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}
          <div class="vcn-option">
            <label class="vcn-option__label">{{ option.name }}</label>
            <div class="vcn-option__values">
              {% for value in option.values %}
                <button class="vcn-option__btn {% if forloop.first %}vcn-option__btn--active{% endif %}"
                        onclick="vcnSelectOption(this, '{{ option.name }}', '{{ value }}')">
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endunless %}

      {%- comment -%} Quantity + ATC {%- endcomment -%}
      {% form 'product', product, id: 'vcn-product-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="vcn-atc-row">
          <div class="vcn-qty">
            <button type="button" class="vcn-qty__btn" onclick="vcnQty(-1)">−</button>
            <input type="number" name="quantity" value="1" min="1" class="vcn-qty__input" id="vcn-qty">
            <button type="button" class="vcn-qty__btn" onclick="vcnQty(1)">+</button>
          </div>
          <button type="submit" name="add" class="vcn-atc-btn">
            🛒 Thêm Vào Giỏ
          </button>
        </div>

        <a href="{{ product.url }}?variant={{ product.selected_or_first_available_variant.id }}&selling_plan=0"
           class="vcn-buy-now-btn"
           onclick="this.href='{{ product.url }}?variant={{ product.selected_or_first_available_variant.id }}&checkout=true'">
          Mua Ngay — Giao 1–3 Ngày
        </a>
      {% endform %}

      {%- comment -%} Trust badges {%- endcomment -%}
      <div class="vcn-trust">
        <div class="vcn-trust__item">
          <span class="vcn-trust__icon">🚚</span>
          <div>
            <strong>Free Ship</strong>
            <p>Đơn từ 500K</p>
          </div>
        </div>
        <div class="vcn-trust__item">
          <span class="vcn-trust__icon">🔄</span>
          <div>
            <strong>Đổi Trả 7 Ngày</strong>
            <p>Lỗi sản phẩm</p>
          </div>
        </div>
        <div class="vcn-trust__item">
          <span class="vcn-trust__icon">🔒</span>
          <div>
            <strong>Thanh Toán An Toàn</strong>
            <p>SSL bảo mật</p>
          </div>
        </div>
        <div class="vcn-trust__item">
          <span class="vcn-trust__icon">⭐</span>
          <div>
            <strong>4.9/5 Sao</strong>
            <p>127 đánh giá</p>
          </div>
        </div>
      </div>

      {%- comment -%} Collapsible details {%- endcomment -%}
      <div class="vcn-accordions">
        <details class="vcn-accordion" open>
          <summary class="vcn-accordion__trigger">Mô Tả Sản Phẩm</summary>
          <div class="vcn-accordion__body vcn-product__desc" itemprop="description">
            {{ product.description }}
          </div>
        </details>
        <details class="vcn-accordion">
          <summary class="vcn-accordion__trigger">Thông Tin Giao Hàng</summary>
          <div class="vcn-accordion__body">
            <ul>
              <li>Giao hàng toàn quốc 1–3 ngày làm việc</li>
              <li>Free ship đơn từ 500,000 VND</li>
              <li>Đóng gói chắc chắn, bảo vệ sản phẩm</li>
              <li>Có thể theo dõi đơn hàng qua Zalo</li>
            </ul>
          </div>
        </details>
        <details class="vcn-accordion">
          <summary class="vcn-accordion__trigger">Chính Sách Đổi Trả</summary>
          <div class="vcn-accordion__body">
            <ul>
              <li>Đổi trả miễn phí trong 7 ngày nếu lỗi sản phẩm</li>
              <li>Sản phẩm phải còn nguyên tem, chưa qua sử dụng</li>
              <li>Liên hệ Zalo để được hỗ trợ nhanh nhất</li>
            </ul>
          </div>
        </details>
      </div>

    </div>
  </div>

  {%- comment -%} Social proof strip {%- endcomment -%}
  <div class="vcn-social-proof">
    <div class="vcn-sp-item">✅ Đã bán <strong>2,400+</strong> sản phẩm</div>
    <div class="vcn-sp-dot">•</div>
    <div class="vcn-sp-item">📦 Kho hàng sẵn — giao ngay hôm nay</div>
    <div class="vcn-sp-dot">•</div>
    <div class="vcn-sp-item">💬 Hỗ trợ Zalo trong <strong>1 giờ</strong></div>
  </div>

</div>

<style>
.vcn-product { background: #0a0a0f; color: #fff; min-height: 100vh; }
.vcn-product__layout {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  padding: 4rem 4vw;
  align-items: start;
}
.vcn-product__main-img {
  position: sticky;
  top: 2rem;
  border-radius: 16px;
  overflow: hidden;
  background: rgba(139,92,246,0.05);
  border: 1px solid rgba(255,255,255,0.07);
  position: relative;
}
.vcn-product__main-img img { width: 100%; display: block; }
.vcn-product__img-placeholder {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.vcn-product__img-placeholder svg { width: 140px; }
.vcn-product__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #ef4444;
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.3rem 0.7rem;
  border-radius: 6px;
}
.vcn-product__thumbs { display: flex; gap: 0.6rem; margin-top: 0.8rem; flex-wrap: wrap; }
.vcn-thumb {
  width: 64px;
  height: 64px;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid rgba(255,255,255,0.1);
  cursor: pointer;
  padding: 0;
  background: none;
  transition: border-color 0.2s;
}
.vcn-thumb img { width: 100%; height: 100%; object-fit: cover; }
.vcn-thumb--active { border-color: #8B5CF6; }
.vcn-thumb:hover { border-color: rgba(139,92,246,0.6); }
.vcn-product__stars { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; }
.vcn-stars-fill { color: #f59e0b; font-size: 1rem; }
.vcn-stars-count { color: rgba(255,255,255,0.5); font-size: 0.82rem; }
.vcn-product__title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 800;
  line-height: 1.2;
  color: #fff;
  margin-bottom: 1.2rem;
}
.vcn-product__price { display: flex; align-items: baseline; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1rem; }
.vcn-price-current { font-size: 1.8rem; font-weight: 800; color: #fff; }
.vcn-price-original { font-size: 1.1rem; color: rgba(255,255,255,0.35); text-decoration: line-through; }
.vcn-price-save {
  font-size: 0.8rem;
  font-weight: 600;
  background: rgba(239,68,68,0.15);
  color: #f87171;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
}
.vcn-urgency {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.2);
  border-radius: 8px;
  padding: 0.7rem 1rem;
  font-size: 0.88rem;
  color: rgba(255,255,255,0.8);
  margin-bottom: 1.5rem;
}
.vcn-urgency__dot {
  width: 8px;
  height: 8px;
  background: #ef4444;
  border-radius: 50%;
  animation: vcn-blink 1.2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes vcn-blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.vcn-option { margin-bottom: 1.2rem; }
.vcn-option__label { display: block; font-size: 0.82rem; color: rgba(255,255,255,0.5); margin-bottom: 0.5rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; }
.vcn-option__values { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.vcn-option__btn {
  padding: 0.5rem 1.1rem;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.04);
  color: rgba(255,255,255,0.7);
  font-size: 0.88rem;
  cursor: pointer;
  transition: all 0.15s;
}
.vcn-option__btn:hover { border-color: #8B5CF6; color: #fff; }
.vcn-option__btn--active { border-color: #8B5CF6; background: rgba(139,92,246,0.15); color: #fff; }
.vcn-atc-row { display: flex; gap: 0.8rem; margin-bottom: 0.8rem; }
.vcn-qty {
  display: flex;
  align-items: center;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 10px;
  overflow: hidden;
  flex-shrink: 0;
}
.vcn-qty__btn {
  width: 40px;
  height: 52px;
  background: rgba(255,255,255,0.06);
  border: none;
  color: #fff;
  font-size: 1.2rem;
  cursor: pointer;
  transition: background 0.15s;
}
.vcn-qty__btn:hover { background: rgba(139,92,246,0.2); }
.vcn-qty__input {
  width: 48px;
  height: 52px;
  text-align: center;
  background: transparent;
  border: none;
  color: #fff;
  font-size: 1rem;
  font-weight: 600;
}
.vcn-qty__input::-webkit-outer-spin-button,
.vcn-qty__input::-webkit-inner-spin-button { -webkit-appearance: none; }
.vcn-atc-btn {
  flex: 1;
  height: 52px;
  background: #8B5CF6;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 0 20px rgba(139,92,246,0.4);
}
.vcn-atc-btn:hover { background: #7c3aed; box-shadow: 0 0 30px rgba(139,92,246,0.6); transform: translateY(-1px); }
.vcn-buy-now-btn {
  display: block;
  width: 100%;
  height: 52px;
  line-height: 52px;
  text-align: center;
  background: transparent;
  color: rgba(255,255,255,0.8);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s;
  margin-bottom: 1.5rem;
}
.vcn-buy-now-btn:hover { border-color: #8B5CF6; color: #fff; background: rgba(139,92,246,0.08); }
.vcn-trust {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.8rem;
  padding: 1.2rem;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  margin-bottom: 1.5rem;
}
.vcn-trust__item { display: flex; align-items: center; gap: 0.6rem; }
.vcn-trust__icon { font-size: 1.2rem; }
.vcn-trust__item strong { display: block; font-size: 0.8rem; color: #fff; }
.vcn-trust__item p { font-size: 0.72rem; color: rgba(255,255,255,0.4); margin: 0; }
.vcn-accordions { border-top: 1px solid rgba(255,255,255,0.08); }
.vcn-accordion { border-bottom: 1px solid rgba(255,255,255,0.08); }
.vcn-accordion__trigger {
  width: 100%;
  padding: 1rem 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  font-size: 0.92rem;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  list-style: none;
  user-select: none;
}
.vcn-accordion__trigger::after { content: '+'; font-size: 1.2rem; color: #8B5CF6; }
details[open] .vcn-accordion__trigger::after { content: '−'; }
.vcn-accordion__body {
  padding-bottom: 1rem;
  color: rgba(255,255,255,0.55);
  font-size: 0.88rem;
  line-height: 1.7;
}
.vcn-accordion__body ul { padding-left: 1.2rem; }
.vcn-accordion__body li { margin-bottom: 0.4rem; }
.vcn-product__desc { color: rgba(255,255,255,0.6); }
.vcn-product__desc p { margin-bottom: 0.8rem; }
.vcn-product__desc ul { padding-left: 1.2rem; }
.vcn-product__desc li { margin-bottom: 0.3rem; }
.vcn-social-proof {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 1.2rem 4vw;
  background: rgba(139,92,246,0.08);
  border-top: 1px solid rgba(139,92,246,0.2);
  font-size: 0.88rem;
  color: rgba(255,255,255,0.65);
  flex-wrap: wrap;
}
.vcn-sp-dot { color: rgba(255,255,255,0.2); }
.vcn-social-proof strong { color: #fff; }
@media(max-width:768px){
  .vcn-product__layout { grid-template-columns: 1fr; padding: 2rem 5vw; gap: 2rem; }
  .vcn-trust { grid-template-columns: 1fr 1fr; }
  .vcn-atc-row { flex-direction: column; }
  .vcn-atc-btn, .vcn-buy-now-btn { width: 100%; }
  .vcn-social-proof { gap: 0.8rem; font-size: 0.8rem; }
  .vcn-sp-dot { display: none; }
}
</style>

<script>
function vcnSwitchImg(src, btn) {
  document.getElementById('vcn-main-img-el').src = src;
  document.querySelectorAll('.vcn-thumb').forEach(t => t.classList.remove('vcn-thumb--active'));
  btn.classList.add('vcn-thumb--active');
}
function vcnQty(delta) {
  const input = document.getElementById('vcn-qty');
  const newVal = Math.max(1, parseInt(input.value) + delta);
  input.value = newVal;
}
function vcnSelectOption(btn, optionName, value) {
  btn.closest('.vcn-option__values').querySelectorAll('.vcn-option__btn').forEach(b => b.classList.remove('vcn-option__btn--active'));
  btn.classList.add('vcn-option__btn--active');
}
</script>
