{% comment %} VCN Featured Products Section {% endcomment %}
<section class="vcn-featured" id="vcn-products">
  <div class="vcn-featured__header">
    <p class="vcn-section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="vcn-section-title">{{ section.settings.title }}</h2>
    <p class="vcn-section-sub">{{ section.settings.subtitle }}</p>
  </div>

  <div class="vcn-products-grid">
    {% assign collection = collections[section.settings.collection] %}
    {% if collection != blank %}
      {% for product in collection.products limit: section.settings.products_count %}
        <a href="{{ product.url }}" class="vcn-product-card">
          <div class="vcn-product-card__img-wrap">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}"
                   alt="{{ product.title }}" loading="lazy">
            {% else %}
              <div class="vcn-product-card__no-img">
                <svg viewBox="0 0 80 80" fill="none"><circle cx="40" cy="40" r="25" stroke="rgba(139,92,246,0.5)" stroke-width="1.5"/><circle cx="40" cy="40" r="5" fill="#8B5CF6"/></svg>
              </div>
            {% endif %}
            {% if product.compare_at_price > product.price %}
              <span class="vcn-badge vcn-badge--sale">
                -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}%
              </span>
            {% endif %}
          </div>
          <div class="vcn-product-card__info">
            <h3 class="vcn-product-card__title">{{ product.title }}</h3>
            <div class="vcn-product-card__price">
              <span class="vcn-price vcn-price--current">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="vcn-price vcn-price--original">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
            <div class="vcn-product-card__stars">★★★★★ <span>({{ product.metafields.reviews.rating_count | default: '4.9' }})</span></div>
          </div>
          <div class="vcn-product-card__hover">
            <span>Xem Chi Tiết →</span>
          </div>
        </a>
      {% endfor %}
    {% else %}
      {% for product in shop.products limit: section.settings.products_count %}
        <a href="{{ product.url }}" class="vcn-product-card">
          <div class="vcn-product-card__img-wrap">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
            {% else %}
              <div class="vcn-product-card__no-img">
                <svg viewBox="0 0 80 80" fill="none"><circle cx="40" cy="40" r="25" stroke="rgba(139,92,246,0.5)" stroke-width="1.5"/><circle cx="40" cy="40" r="5" fill="#8B5CF6"/></svg>
              </div>
            {% endif %}
          </div>
          <div class="vcn-product-card__info">
            <h3 class="vcn-product-card__title">{{ product.title }}</h3>
            <div class="vcn-product-card__price">
              <span class="vcn-price vcn-price--current">{{ product.price | money }}</span>
            </div>
            <div class="vcn-product-card__stars">★★★★★ <span>(4.9)</span></div>
          </div>
          <div class="vcn-product-card__hover"><span>Xem Chi Tiết →</span></div>
        </a>
      {% endfor %}
    {% endif %}
  </div>

  <div class="vcn-featured__cta">
    <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="vcn-btn vcn-btn--primary">
      Xem Tất Cả Sản Phẩm
    </a>
  </div>
</section>

<style>
.vcn-featured {
  background: #0d0d14;
  padding: 6rem 6vw;
}
.vcn-featured__header { text-align: center; margin-bottom: 3.5rem; }
.vcn-section-eyebrow {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #8B5CF6;
  margin-bottom: 0.75rem;
}
.vcn-section-title {
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 800;
  color: #fff;
  margin-bottom: 0.75rem;
}
.vcn-section-sub { color: rgba(255,255,255,0.5); font-size: 1rem; }
.vcn-products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 1.5rem;
  margin-bottom: 3rem;
}
.vcn-product-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  transition: all 0.25s;
  position: relative;
  cursor: pointer;
  display: block;
}
.vcn-product-card:hover {
  border-color: rgba(139,92,246,0.5);
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(139,92,246,0.15);
}
.vcn-product-card__img-wrap {
  aspect-ratio: 1;
  overflow: hidden;
  background: rgba(139,92,246,0.05);
  position: relative;
}
.vcn-product-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s;
}
.vcn-product-card:hover .vcn-product-card__img-wrap img { transform: scale(1.04); }
.vcn-product-card__no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.vcn-product-card__no-img svg { width: 80px; height: 80px; }
.vcn-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  padding: 0.25rem 0.6rem;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 700;
}
.vcn-badge--sale { background: #ef4444; color: #fff; }
.vcn-product-card__info { padding: 1.1rem 1.2rem 1.2rem; }
.vcn-product-card__title {
  font-size: 0.95rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: 0.5rem;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.vcn-product-card__price { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; }
.vcn-price--current { font-size: 1.05rem; font-weight: 700; color: #fff; }
.vcn-price--original { font-size: 0.85rem; color: rgba(255,255,255,0.35); text-decoration: line-through; }
.vcn-product-card__stars { font-size: 0.75rem; color: #f59e0b; }
.vcn-product-card__stars span { color: rgba(255,255,255,0.4); font-size: 0.7rem; }
.vcn-product-card__hover {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(139,92,246,0.9), transparent);
  padding: 1.5rem 1.2rem 1rem;
  transform: translateY(100%);
  transition: transform 0.25s;
  text-align: center;
}
.vcn-product-card__hover span { color: #fff; font-weight: 600; font-size: 0.9rem; }
.vcn-product-card:hover .vcn-product-card__hover { transform: translateY(0); }
.vcn-featured__cta { text-align: center; }
@media(max-width:640px){
  .vcn-featured { padding: 4rem 5vw; }
  .vcn-products-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
}
</style>

{% schema %}
{
  "name": "VCN Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bán Chạy Nhất" },
    { "type": "text", "id": "title", "label": "Title", "default": "Sản Phẩm Nổi Bật" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Được hơn 2,400 collector tin chọn" },
    { "type": "collection", "id": "collection", "label": "Collection to display" },
    { "type": "range", "id": "products_count", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "presets": [{ "name": "VCN Featured Products" }]
}
{% endschema %}
