{% comment %} VCN Navbar {% endcomment %}
<header class="vcn-nav" id="vcn-nav">
  <div class="vcn-nav__inner">
    <a href="/" class="vcn-nav__logo">
      {% if section.settings.logo %}
        <img src="{{ section.settings.logo | img_url: '160x40' }}" alt="{{ shop.name }}" height="36">
      {% else %}
        <span class="vcn-nav__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="vcn-nav__links" id="vcn-nav-links">
      <a href="/collections/all" class="vcn-nav__link">Sản Phẩm</a>
      <a href="/collections/den-led-mo-hinh" class="vcn-nav__link">Đèn LED</a>
      <a href="/collections/den-neon-ky-tu" class="vcn-nav__link">Đèn Neon</a>
      <a href="/pages/ve-chung-toi" class="vcn-nav__link">Về Chúng Tôi</a>
      <a href="/pages/lien-he" class="vcn-nav__link">Liên Hệ</a>
    </nav>

    <div class="vcn-nav__actions">
      <a href="/cart" class="vcn-nav__cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="vcn-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <button class="vcn-nav__hamburger" id="vcn-hamburger" onclick="vcnToggleNav()">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
.vcn-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10,10,15,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  transition: background 0.3s;
}
.vcn-nav__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4vw;
  height: 64px;
}
.vcn-nav__logo { text-decoration: none; }
.vcn-nav__logo-text {
  font-size: 1.3rem;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #fff, #c4b5fd);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.02em;
}
.vcn-nav__links { display: flex; align-items: center; gap: 0.25rem; }
.vcn-nav__link {
  padding: 0.4rem 0.9rem;
  border-radius: 8px;
  color: rgba(255,255,255,0.65);
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 500;
  transition: all 0.15s;
}
.vcn-nav__link:hover { color: #fff; background: rgba(255,255,255,0.07); }
.vcn-nav__actions { display: flex; align-items: center; gap: 1rem; }
.vcn-nav__cart {
  position: relative;
  color: rgba(255,255,255,0.8);
  text-decoration: none;
  transition: color 0.15s;
}
.vcn-nav__cart:hover { color: #fff; }
.vcn-cart-count {
  position: absolute;
  top: -6px;
  right: -8px;
  background: #8B5CF6;
  color: #fff;
  font-size: 0.65rem;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.vcn-nav__hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.vcn-nav__hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: rgba(255,255,255,0.8);
  border-radius: 2px;
  transition: all 0.2s;
}
@media(max-width:768px){
  .vcn-nav__hamburger { display: flex; }
  .vcn-nav__links {
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background: rgba(10,10,15,0.98);
    flex-direction: column;
    padding: 1.5rem 5vw;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    transform: translateY(-20px);
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s;
  }
  .vcn-nav__links.vcn-nav--open { transform: translateY(0); opacity: 1; pointer-events: all; }
  .vcn-nav__link { padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); width: 100%; }
}
</style>

<script>
function vcnToggleNav() {
  document.getElementById('vcn-nav-links').classList.toggle('vcn-nav--open');
}
window.addEventListener('scroll', function() {
  const nav = document.getElementById('vcn-nav');
  if (window.scrollY > 20) {
    nav.style.background = 'rgba(10,10,15,0.98)';
  } else {
    nav.style.background = 'rgba(10,10,15,0.92)';
  }
});
</script>

{% schema %}
{
  "name": "VCN Navbar",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (optional)" }
  ],
  "presets": [{ "name": "VCN Navbar" }]
}
{% endschema %}
