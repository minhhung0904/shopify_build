{% comment %} VCN Hero Section — Homepage {% endcomment %}
<section class="vcn-hero" id="vcn-hero">
  <div class="vcn-hero__bg"></div>
  <div class="vcn-hero__content">
    <p class="vcn-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="vcn-hero__title">{{ section.settings.title }}</h1>
    <p class="vcn-hero__subtitle">{{ section.settings.subtitle }}</p>
    <div class="vcn-hero__ctas">
      <a href="{{ section.settings.primary_btn_link }}" class="vcn-btn vcn-btn--primary">
        {{ section.settings.primary_btn_text }}
      </a>
      <a href="{{ section.settings.secondary_btn_link }}" class="vcn-btn vcn-btn--ghost">
        {{ section.settings.secondary_btn_text }}
      </a>
    </div>
    <div class="vcn-hero__stats">
      <div class="vcn-stat">
        <span class="vcn-stat__num">2,400+</span>
        <span class="vcn-stat__label">Khách hàng</span>
      </div>
      <div class="vcn-stat">
        <span class="vcn-stat__num">4.9★</span>
        <span class="vcn-stat__label">Đánh giá</span>
      </div>
      <div class="vcn-stat">
        <span class="vcn-stat__num">7 ngày</span>
        <span class="vcn-stat__label">Đổi trả miễn phí</span>
      </div>
    </div>
  </div>
  <div class="vcn-hero__visual">
    {% if section.settings.hero_image != blank %}
      <img src="{{ section.settings.hero_image | img_url: '800x800' }}" alt="{{ section.settings.title }}" loading="eager">
    {% else %}
      <div class="vcn-hero__placeholder">
        <div class="vcn-glow-orb"></div>
        <svg viewBox="0 0 200 200" class="vcn-hero__icon">
          <circle cx="100" cy="100" r="60" fill="none" stroke="rgba(139,92,246,0.6)" stroke-width="2"/>
          <circle cx="100" cy="100" r="40" fill="rgba(139,92,246,0.15)"/>
          <circle cx="100" cy="100" r="8" fill="#8B5CF6"/>
          {% for i in (1..8) %}
            <line x1="100" y1="100" x2="100" y2="50" stroke="rgba(139,92,246,0.4)" stroke-width="1.5"
              transform="rotate({{ i | times: 45 }} 100 100)"/>
          {% endfor %}
        </svg>
      </div>
    {% endif %}
  </div>
</section>

<style>
.vcn-hero {
  position: relative;
  min-height: 90vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
  padding: 6rem 6vw;
  background: #0a0a0f;
  overflow: hidden;
}
.vcn-hero__bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 60% at 70% 50%, rgba(139,92,246,0.12) 0%, transparent 70%),
              radial-gradient(ellipse 40% 40% at 20% 80%, rgba(59,130,246,0.08) 0%, transparent 60%);
  pointer-events: none;
}
.vcn-hero__content { position: relative; z-index: 1; }
.vcn-hero__eyebrow {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #8B5CF6;
  margin-bottom: 1rem;
}
.vcn-hero__title {
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  font-weight: 800;
  line-height: 1.1;
  color: #fff;
  margin-bottom: 1.2rem;
  background: linear-gradient(135deg, #fff 60%, #c4b5fd);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.vcn-hero__subtitle {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.6);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: 2.5rem;
}
.vcn-hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
.vcn-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.85rem 2rem;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  transition: all 0.2s;
  cursor: pointer;
}
.vcn-btn--primary {
  background: #8B5CF6;
  color: #fff;
  box-shadow: 0 0 20px rgba(139,92,246,0.4);
}
.vcn-btn--primary:hover { background: #7c3aed; box-shadow: 0 0 30px rgba(139,92,246,0.6); transform: translateY(-1px); }
.vcn-btn--ghost {
  background: transparent;
  color: rgba(255,255,255,0.8);
  border: 1px solid rgba(255,255,255,0.2);
}
.vcn-btn--ghost:hover { border-color: #8B5CF6; color: #fff; }
.vcn-hero__stats { display: flex; gap: 2.5rem; }
.vcn-stat { display: flex; flex-direction: column; }
.vcn-stat__num { font-size: 1.4rem; font-weight: 700; color: #fff; }
.vcn-stat__label { font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.2rem; }
.vcn-hero__visual { position: relative; display: flex; align-items: center; justify-content: center; }
.vcn-hero__visual img { width: 100%; max-width: 520px; border-radius: 16px; box-shadow: 0 0 60px rgba(139,92,246,0.25); }
.vcn-hero__placeholder { width: 380px; height: 380px; display: flex; align-items: center; justify-content: center; position: relative; }
.vcn-glow-orb {
  position: absolute;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(139,92,246,0.2) 0%, transparent 70%);
  border-radius: 50%;
  animation: vcn-pulse 3s ease-in-out infinite;
}
.vcn-hero__icon { width: 200px; height: 200px; position: relative; z-index: 1; }
@keyframes vcn-pulse { 0%,100%{transform:scale(1);opacity:0.8} 50%{transform:scale(1.1);opacity:1} }
@media(max-width:768px){
  .vcn-hero { grid-template-columns: 1fr; padding: 4rem 5vw; min-height: auto; }
  .vcn-hero__visual { order: -1; }
  .vcn-hero__placeholder { width: 220px; height: 220px; }
  .vcn-hero__stats { gap: 1.5rem; }
}
</style>

{% schema %}
{
  "name": "VCN Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Đèn Mô Hình Cao Cấp" },
    { "type": "text", "id": "title", "label": "Title", "default": "Thắp Sáng Bộ Sưu Tập Của Bạn" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Đèn LED chuyên dụng cho mô hình, figure và diorama. Thiết kế tối giản, ánh sáng chuyên nghiệp." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "primary_btn_text", "label": "Primary button", "default": "Mua Ngay" },
    { "type": "url", "id": "primary_btn_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_btn_text", "label": "Secondary button", "default": "Xem Bộ Sưu Tập" },
    { "type": "url", "id": "secondary_btn_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "VCN Hero" }]
}
{% endschema %}
