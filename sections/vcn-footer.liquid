{% comment %} VCN Footer {% endcomment %}
<footer class="vcn-footer">
  <div class="vcn-footer__inner">
    <div class="vcn-footer__brand">
      <a href="/" class="vcn-nav__logo-text vcn-footer__logo">{{ shop.name }}</a>
      <p class="vcn-footer__tagline">Ánh sáng xứng đáng với niềm đam mê của bạn.</p>
      <div class="vcn-footer__socials">
        {% if section.settings.facebook != blank %}
          <a href="{{ section.settings.facebook }}" class="vcn-social" target="_blank" rel="noopener">FB</a>
        {% endif %}
        {% if section.settings.tiktok != blank %}
          <a href="{{ section.settings.tiktok }}" class="vcn-social" target="_blank" rel="noopener">TT</a>
        {% endif %}
        {% if section.settings.zalo != blank %}
          <a href="{{ section.settings.zalo }}" class="vcn-social" target="_blank" rel="noopener">ZL</a>
        {% endif %}
      </div>
    </div>

    <div class="vcn-footer__col">
      <h4 class="vcn-footer__heading">Sản Phẩm</h4>
      <a href="/collections/den-led-mo-hinh" class="vcn-footer__link">Đèn LED Mô Hình</a>
      <a href="/collections/den-neon-ky-tu" class="vcn-footer__link">Đèn Neon Ký Tự</a>
      <a href="/collections/den-trang-tri-phong" class="vcn-footer__link">Đèn Trang Trí Phòng</a>
      <a href="/collections/all" class="vcn-footer__link">Tất Cả Sản Phẩm</a>
    </div>

    <div class="vcn-footer__col">
      <h4 class="vcn-footer__heading">Hỗ Trợ</h4>
      <a href="/pages/ve-chung-toi" class="vcn-footer__link">Về Chúng Tôi</a>
      <a href="/pages/lien-he" class="vcn-footer__link">Liên Hệ</a>
      <a href="/pages/chinh-sach-van-chuyen" class="vcn-footer__link">Chính Sách Vận Chuyển</a>
      <a href="/policies/refund-policy" class="vcn-footer__link">Chính Sách Đổi Trả</a>
    </div>

    <div class="vcn-footer__col">
      <h4 class="vcn-footer__heading">Liên Hệ Nhanh</h4>
      <p class="vcn-footer__contact">Zalo: {{ section.settings.zalo_number | default: '0xxx xxx xxx' }}</p>
      <p class="vcn-footer__contact">Hỗ trợ 8h – 22h mỗi ngày</p>
      <p class="vcn-footer__contact">{{ section.settings.email | default: 'support@vcnstore.vn' }}</p>
    </div>
  </div>

  <div class="vcn-footer__bottom">
    <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Tất cả quyền được bảo lưu.</p>
    <div class="vcn-footer__policies">
      <a href="/policies/privacy-policy">Chính sách bảo mật</a>
      <span>·</span>
      <a href="/policies/terms-of-service">Điều khoản dịch vụ</a>
    </div>
  </div>
</footer>

<style>
.vcn-footer {
  background: #07070d;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 4rem 6vw 0;
}
.vcn-footer__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.vcn-footer__logo {
  display: block;
  font-size: 1.4rem;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #fff, #c4b5fd);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-decoration: none;
  margin-bottom: 0.8rem;
}
.vcn-footer__tagline { color: rgba(255,255,255,0.35); font-size: 0.88rem; line-height: 1.6; margin-bottom: 1.2rem; }
.vcn-footer__socials { display: flex; gap: 0.5rem; }
.vcn-social {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  font-size: 0.72rem;
  font-weight: 700;
  transition: all 0.15s;
}
.vcn-social:hover { border-color: #8B5CF6; color: #fff; background: rgba(139,92,246,0.1); }
.vcn-footer__heading {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 1rem;
}
.vcn-footer__link {
  display: block;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  font-size: 0.88rem;
  margin-bottom: 0.6rem;
  transition: color 0.15s;
}
.vcn-footer__link:hover { color: #fff; }
.vcn-footer__contact { color: rgba(255,255,255,0.45); font-size: 0.85rem; margin-bottom: 0.5rem; }
.vcn-footer__bottom {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 0;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.25);
  flex-wrap: wrap;
  gap: 0.5rem;
}
.vcn-footer__policies { display: flex; gap: 0.5rem; }
.vcn-footer__policies a { color: rgba(255,255,255,0.25); text-decoration: none; }
.vcn-footer__policies a:hover { color: rgba(255,255,255,0.5); }
@media(max-width:768px){
  .vcn-footer { padding: 3rem 5vw 0; }
  .vcn-footer__inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
  .vcn-footer__brand { grid-column: 1 / -1; }
}
@media(max-width:480px){
  .vcn-footer__inner { grid-template-columns: 1fr; }
}
</style>

{% schema %}
{
  "name": "VCN Footer",
  "settings": [
    { "type": "text", "id": "facebook", "label": "Facebook URL" },
    { "type": "text", "id": "tiktok", "label": "TikTok URL" },
    { "type": "text", "id": "zalo", "label": "Zalo URL" },
    { "type": "text", "id": "zalo_number", "label": "Zalo number", "default": "0xxx xxx xxx" },
    { "type": "text", "id": "email", "label": "Email", "default": "support@vcnstore.vn" }
  ],
  "presets": [{ "name": "VCN Footer" }]
}
{% endschema %}
