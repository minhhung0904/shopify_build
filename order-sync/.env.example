# Shopify — filled in by `shopify app config link` / the Partner Dashboard
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.onrender.com
SCOPES=read_orders

# MongoDB — session storage, per-shop tokens, synced-order dedupe
DATABASE_URL=mongodb+srv://user:pass@cluster/
MONGO_DB_NAME=order-sync

# Encrypts merchant platform tokens at rest. Generate with:
#   openssl rand -base64 32
# Rotating this makes every stored token unreadable — merchants must reconnect.
ENCRYPTION_KEY=

# The platform. One deployment for every merchant, so the URL lives here while
# each merchant's token lives in the database.
PLATFORM_API_URL=https://your-platform.com/api
PLATFORM_ORDERS_PATH=/orders
# Optional: endpoint that validates a token when a merchant connects. Leave
# empty to accept tokens without checking them.
PLATFORM_VERIFY_PATH=

# Keep under 5000 — Shopify times the webhook out at 5s and redelivers.
PLATFORM_TIMEOUT_MS=3000
